<!-- ── Quantrix single-quote convention edge cases ─────────────── -->

<test>
<name>quoting: :: inside quoted view name</name>
<input>|'Matrix::Formula'::1|</input>
<expected>getSelection("'Matrix::Formula'::1")</expected>
</test>

<test>
<name>quoting: double-quote in name escaped for Groovy string</name>
<input>|'Matrix"Test'::A|</input>
<expected>getSelection("'Matrix\"Test'::A")</expected>
</test>

<test>
<name>quoting: dollar in name escaped for Groovy string</name>
<input>|'Price$'::A|</input>
<expected>getSelection("'Price\$'::A")</expected>
</test>

<test>
<name>quoting: backslash in quoted name escaped for Groovy string</name>
<input>|'Back\slash'::A|</input>
<expected>getSelection("'Back\\slash'::A")</expected>
</test>

<test>
<name>quoting: formula vs cell - double colon</name>
<input>|Matrix::Formula::1|</input>
<expected>getSelection("Matrix::Formula::1")</expected>
</test>

<test>
<name>quoting: formula vs cell - single colon</name>
<input>|Matrix::Formula:1|</input>
<expected>getSelection("Matrix::Formula:1")</expected>
</test>

<test>
<name>quoting: doubled single quote (Quantrix convention)</name>
<input>|Matrix::'Shareholder''s Equity'|</input>
<expected>getSelection("Matrix::'Shareholder''s Equity'")</expected>
</test>

<test>
<name>quoting: pipe inside single-quoted name</name>
<input>|Matrix::'Name|Here'|</input>
<expected>getSelection("Matrix::'Name|Here'")</expected>
</test>

<test>
<name>quoting: special chars in quoted name</name>
<input>|Matrix::'Total (2020+)'|</input>
<expected>getSelection("Matrix::'Total (2020+)'")</expected>
</test>

<test>
<name>quoting: doubled single quote in view name</name>
<input>|'Matt''s Model'::A|</input>
<expected>getSelection("'Matt''s Model'::A")</expected>
</test>

<test>
<name>quoting: multiple quoted items with special chars</name>
<input>|Matrix::'A+B':'Year (1)'|</input>
<expected>getSelection("Matrix::'A+B':'Year (1)'")</expected>
</test>
