<!--
  Test cases for SelectionPreprocessor.

  Format: each test block has a name, an input, and an optional expected
  output. If expected is omitted, the output must equal the input
  (no transformation).

  This file deliberately uses simplified XML parsing (tag scanning, not a
  full XML parser). The advantage is that the sensitive characters of
  Groovy/Java (backslashes, quotes, dollar signs) are inert in XML, and
  the sensitive characters of XML are inert in Groovy. This near-disjoint
  overlap means test content needs no escaping — what you see between the
  tags is the exact literal string under test.

  The only content that would confuse the parser is a closing tag
  appearing literally inside test data (effectively impossible for
  Groovy source code). XML comments like this one are harmless — they
  appear between test blocks and are skipped by the tag scanner.
-->

<test>
<name>simple pipe</name>
<input>|Balance Sheet::Cash:2020|.value</input>
<expected>getSelection("Balance Sheet::Cash:2020").value</expected>
</test>

<test>
<name>pipe with single-quoted name</name>
<input>|Matrix::'Item Name':2020|</input>
<expected>getSelection("Matrix::'Item Name':2020")</expected>
</test>

<test>
<name>multiple pipes</name>
<input>[|A::B|, |C::D|]</input>
<expected>[getSelection("A::B"), getSelection("C::D")]</expected>
</test>

<test>
<name>pipe in assignment</name>
<input>def x = |A::B|</input>
<expected>def x = getSelection("A::B")</expected>
</test>

<test>
<name>pipe with method call</name>
<input>|Revenue::Total|.formattedValue</input>
<expected>getSelection("Revenue::Total").formattedValue</expected>
</test>

<!-- Command expressions: println |A::B| is ambiguous — after an identifier,
     | is binary OR per GroovyLexer conventions (same as / being division
     after an identifier, not regex). Use parentheses: println(|A::B|). -->

<test>
<name>command expression: pipe after identifier is binary OR</name>
<input>println |A::B|</input>
</test>

<test>
<name>command expression: use parens for pipe argument</name>
<input>println(|A::B|)</input>
<expected>println(getSelection("A::B"))</expected>
</test>

<test>
<name>command expression: pipe with property after identifier is binary OR</name>
<input>foo |A::B|.value</input>
</test>

<test>
<name>command expression: use parens for pipe with property</name>
<input>foo(|A::B|.value)</input>
<expected>foo(getSelection("A::B").value)</expected>
</test>

<test>
<name>pipe after opening paren</name>
<input>println(|A::B|.value)</input>
<expected>println(getSelection("A::B").value)</expected>
</test>

<test>
<name>pipe after comma</name>
<input>[|A::B|.value, |C::D|.value]</input>
<expected>[getSelection("A::B").value, getSelection("C::D").value]</expected>
</test>

<test>
<name>pipe after operator</name>
<input>x + |A::B|.value</input>
<expected>x + getSelection("A::B").value</expected>
</test>

<test>
<name>pipe at start of line</name>
<input>x = 1
|A::B|.value</input>
<expected>x = 1
getSelection("A::B").value</expected>
</test>

<test>
<name>binary OR</name>
<input>x | y</input>
</test>

<test>
<name>logical OR</name>
<input>x || y</input>
</test>

<test>
<name>bitwise OR assignment</name>
<input>x |= 3</input>
</test>

<test>
<name>chained binary OR</name>
<input>a | b | c</input>
</test>

<test>
<name>OR after closing paren</name>
<input>(x) | y</input>
</test>

<test>
<name>OR after closing bracket</name>
<input>a[0] | b</input>
</test>

<test>
<name>OR after closing brace</name>
<input>{x} | y</input>
</test>

<test>
<name>OR after number</name>
<input>0xFF | mask</input>
</test>

<test>
<name>OR after ++</name>
<input>x++ | y</input>
</test>

<test>
<name>OR after --</name>
<input>x-- | y</input>
</test>

<test>
<name>OR after this</name>
<input>this | other</input>
</test>

<test>
<name>OR after true</name>
<input>true | false</input>
</test>

<test>
<name>keyword as member: obj.class is expression-ending</name>
<input>obj.class | mask | extra</input>
</test>

<test>
<name>keyword as member: obj.in is expression-ending</name>
<input>obj.in | mask</input>
</test>

<test>
<name>keyword as member: safe navigation obj?.class</name>
<input>obj?.class | mask</input>
</test>

<test>
<name>keyword as member: spread obj*.class</name>
<input>list*.class | mask</input>
</test>

<test>
<name>keyword as member: whitespace before keyword</name>
<input>obj.  class | mask</input>
</test>

<test>
<name>keyword as member: block comment between dot and keyword</name>
<input>obj./*x*/class | mask | extra</input>
</test>

<test>
<name>keyword as member: newline between dot and keyword</name>
<input>obj.
class | mask</input>
</test>

<test>
<name>keyword as member: line comment then keyword on next line</name>
<input>obj.// get the class
class | mask</input>
</test>

<test>
<name>keyword as member: chained dot-keyword-dot</name>
<input>obj.class.name | mask</input>
</test>

<test>
<name>dot then pipe (AFTER_DOT allows pipe opener)</name>
<input>obj.|Matrix::A|</input>
<expected>obj.getSelection("Matrix::A")</expected>
</test>

<test>
<name>float literal dot does not set AFTER_DOT</name>
<input>1.0 | mask</input>
</test>

<test>
<name>keyword not after dot: return still opens pipe</name>
<input>return |A::B|</input>
<expected>return getSelection("A::B")</expected>
</test>

<test>
<name>keyword not after dot: assert opens pipe</name>
<input>assert |A::B|.value > 0</input>
<expected>assert getSelection("A::B").value > 0</expected>
</test>

<test>
<name>elvis operator with pipe</name>
<input>x ?: |A::B|.value</input>
<expected>x ?: getSelection("A::B").value</expected>
</test>

<test>
<name>two pipes in one expression</name>
<input>x = |A::B| + |C::D|</input>
<expected>x = getSelection("A::B") + getSelection("C::D")</expected>
</test>

<test>
<name>leading whitespace after pipe rejected</name>
<input>x = | A::B|</input>
</test>

<test>
<name>leading tab after pipe rejected</name>
<input>|	A::B|</input>
</test>

<test>
<name>whitespace-only pipe rejected</name>
<input>|   |</input>
</test>

<test>
<name>pipe inside single-quoted string</name>
<input>def s = 'a |pipe| b'</input>
</test>

<test>
<name>pipe inside double-quoted string</name>
<input>def s = "a |pipe| b"</input>
</test>

<test>
<name>pipe inside triple-single-quoted string</name>
<input>def s = '''a |pipe| b'''</input>
</test>

<test>
<name>pipe inside triple-double-quoted string</name>
<input>def s = """a |pipe| b"""</input>
</test>

<test>
<name>string with escaped quote then pipe</name>
<input>def s = 'it\'s |not a pipe|'</input>
</test>

<test>
<name>pipe inside GString interpolation</name>
<input>"value: ${|A::B|.value}"</input>
<expected>"value: ${getSelection("A::B").value}"</expected>
</test>

<test>
<name>nested GString interpolation</name>
<input>"${"inner ${|A::B|}"}  outer"</input>
<expected>"${"inner ${getSelection("A::B")}"}  outer"</expected>
</test>

<test>
<name>interpolation newline leaks outer paren depth</name>
<input>foo("${x
|A::B|}")</input>
<expected>foo("${x
getSelection("A::B")}")</expected>
</test>

<test>
<name>pipe after newline inside interpolation closure</name>
<input>foo("${{ ->
x
|A::B|
}()}")</input>
<expected>foo("${{ ->
x
getSelection("A::B")
}()}")</expected>
</test>

<test>
<name>pipe inside slashy string</name>
<input>def re = /a|b|c/
|A::B|</input>
<expected>def re = /a|b|c/
getSelection("A::B")</expected>
</test>

<test>
<name>slashy string with escaped slash</name>
<input>def re = /a\/b|c/
x</input>
</test>

<test>
<name>division not confused with slashy</name>
<input>x / y | z</input>
</test>

<test>
<name>slashy after operator</name>
<input>x =~ /pattern|alt/</input>
</test>

<test>
<name>slashy GString interpolation with pipe</name>
<input>def re = /prefix${|A::B|.value}suffix/</input>
<expected>def re = /prefix${getSelection("A::B").value}suffix/</expected>
</test>

<test>
<name>multiline slashy string with pipe-like text on later line</name>
<input>def re = /a
x + |A::B|/</input>
</test>

<test>
<name>multiline slashy string preserves later-line content before real pipe</name>
<input>def re = /a
x + |A::B|/
|C::D|</input>
<expected>def re = /a
x + |A::B|/
getSelection("C::D")</expected>
</test>

<test>
<name>tilde-slashy (common regex pattern)</name>
<input>def m = str =~ ~/a|b/</input>
</test>

<test>
<name>pipe inside dollar-slashy string</name>
<input>def re = $/a|b|c/$
|A::B|</input>
<expected>def re = $/a|b|c/$
getSelection("A::B")</expected>
</test>

<test>
<name>dollar-slashy with escape</name>
