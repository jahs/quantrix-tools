<!-- ── Real-world pipe expressions from Quantrix tutorial models ── -->

<test>
<name>corpus: view only (no ::)</name>
<input>|Matrix1|.categories.each { println it }</input>
<expected>getSelection("Matrix1").categories.each { println it }</expected>
</test>

<test>
<name>corpus: empty range selects all</name>
<input>|Matrix1::|.backgroundColor = "none"</input>
<expected>getSelection("Matrix1::").backgroundColor = "none"</expected>
</test>

<test>
<name>corpus: standalone * modifier selects all cells</name>
<input>|Matrix1::*|.backgroundColor = "none"</input>
<expected>getSelection("Matrix1::*").backgroundColor = "none"</expected>
</test>

<test>
<name>corpus: standalone ^ modifier selects all headers</name>
<input>|Matrix1::^|.backgroundColor = "#FFFF99"</input>
<expected>getSelection("Matrix1::^").backgroundColor = "#FFFF99"</expected>
</test>

<test>
<name>corpus: headers only modifier ^</name>
<input>|Sales Projections::Year^|.backgroundColor = "#FFFF99"</input>
<expected>getSelection("Sales Projections::Year^").backgroundColor = "#FFFF99"</expected>
</test>

<test>
<name>corpus: cells only modifier *</name>
<input>|Matrix1::A1*|.value</input>
<expected>getSelection("Matrix1::A1*").value</expected>
</test>

<test>
<name>corpus: range with coordinates</name>
<input>|Matrix1::A1:B1..A2:B2|.value</input>
<expected>getSelection("Matrix1::A1:B1..A2:B2").value</expected>
</test>

<test>
<name>corpus: cell coordinate syntax</name>
<input>x = |Matrix1::<1, 1>-<2, 2>|</input>
<expected>x = getSelection("Matrix1::<1, 1>-<2, 2>")</expected>
</test>

<test>
<name>corpus: quoted view name with chart</name>
<input>|'Matrix1 - Chart1'::A1:B1|.value</input>
<expected>getSelection("'Matrix1 - Chart1'::A1:B1").value</expected>
</test>

<test>
<name>corpus: sub-view Data:: on chart</name>
<input>|'Matrix1 - Chart1'::Data::A1:B1|.value</input>
<expected>getSelection("'Matrix1 - Chart1'::Data::A1:B1").value</expected>
</test>

<test>
<name>corpus: formula selector</name>
<input>|Matrix1::Formula::1|.text</input>
<expected>getSelection("Matrix1::Formula::1").text</expected>
</test>

<test>
<name>corpus: formula range selector</name>
<input>|Matrix1::Formula::2-3|</input>
<expected>getSelection("Matrix1::Formula::2-3")</expected>
</test>

<test>
<name>corpus: all formulas</name>
<input>|Matrix1::Formula::|.backgroundColor = "none"</input>
<expected>getSelection("Matrix1::Formula::").backgroundColor = "none"</expected>
</test>

<test>
<name>corpus: descriptor syntax</name>
<input>|Matrix1::A{Descriptor}|.value</input>
<expected>getSelection("Matrix1::A{Descriptor}").value</expected>
</test>

<test>
<name>corpus: set value via pipe</name>
<input>|Stage::Number|.value = 0</input>
<expected>getSelection("Stage::Number").value = 0</expected>
</test>

<test>
<name>corpus: category children</name>
<input>|Project Assumptions::Scenario|.children.create()</input>
<expected>getSelection("Project Assumptions::Scenario").children.create()</expected>
</test>

<test>
<name>corpus: sub-view empty range</name>
<input>|'Matrix1 - Chart1'::Data::|.backgroundColor = "none"</input>
<expected>getSelection("'Matrix1 - Chart1'::Data::").backgroundColor = "none"</expected>
</test>

<test>
<name>corpus: method call on view</name>
<input>|'Matrix1 - Chart1'|.bringToFront()</input>
